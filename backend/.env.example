# =============================================
# Application
# =============================================
APP_ENV=development          # development | production
APP_SECRET_KEY=change-me-to-random-secret-key-at-least-32-chars
DEBUG=true

# =============================================
# Database
# =============================================
# 本番: PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/linebook
# 開発: SQLite (コメントアウトして切替)
# DATABASE_URL=sqlite:///./linebook.db

# =============================================
# JWT
# =============================================
JWT_SECRET_KEY=change-me-to-another-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================
# LINE (店舗ごとにDBで管理するが、デフォルト値)
# =============================================
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_LIFF_ID=your-liff-id

# =============================================
# Google Calendar OAuth2
# =============================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-app.onrender.com/api/v1/admin/google/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/calendar

# =============================================
# CORS
# =============================================
# カンマ区切りで許可するオリジンを指定
CORS_ORIGINS=http://localhost:3000,https://your-app.onrender.com

# =============================================
# Frontend URL (通知内リンク生成用)
# =============================================
LIFF_BASE_URL=https://liff.line.me/your-liff-id
ADMIN_BASE_URL=https://your-app.onrender.com/admin

# =============================================
# Encryption (個人情報カラム暗号化用 - v2対応)
# =============================================
# FIELD_ENCRYPTION_KEY=base64-encoded-32-byte-key

# =============================================
# Scheduler
# =============================================
SCHEDULER_ENABLED=true
